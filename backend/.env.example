DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fairhire
ENVIRONMENT=development
MAX_UPLOAD_SIZE_MB=10.0
ALLOWED_ORIGINS=["http://localhost:3000"]

# JWT Auth — required, server refuses to start without this
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Webhook secret — required for POST /api/v1/applications/webhook/test-score
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=change-me-to-a-random-secret

# Email — Brevo (primary, free tier, no domain needed)
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=FairHire AI

# Email — Resend (fallback)
RESEND_API_KEY=
RESEND_FROM_EMAIL=FairHire AI <onboarding@resend.dev>

# Email — SMTP (last resort)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# X / Twitter API v2 (optional)
X_ENABLED=false
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Google Forms (optional — requires credentials.json)
GOOGLE_FORMS_ENABLED=false
GOOGLE_CREDENTIALS_PATH=credentials.json
